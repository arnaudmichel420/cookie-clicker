{
  "name": "cookie-clicker",
  "version": "1.0.0",
  "description": "Cookie Clicker avec Express et EJS.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch-path=src src/server.js",
    "seed": "node src/seeds/defaultUserSeed.js",
    "lint": "eslint .",
    "test": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "coverage": "vitest run tests/unit --coverage",
    "coverage:e2e": "vitest run tests/e2e --coverage",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "keywords": [
    "express",
    "ejs",
    "cookie-clicker"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "vitest": "^4.1.4"
  }
}
