<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      rel="stylesheet"
      href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css"
    />
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/pages/game.css" />
  </head>
  <body class="page-game">
    <div class="effects-layer" id="effects-layer" aria-hidden="true"></div>
    <main class="game-shell is-shop-collapsed" data-authenticated="<%= isAuthenticated %>">
      <section class="game-board" aria-labelledby="game-title">
        <p class="game-brand">Sovereign Clicker</p>
        <div class="cookie-counter">
          <p class="eyebrow">Trump dollars</p>
          <h1 id="game-title"><span id="cookie-count">$<%= formattedCookies %></span></h1>
        </div>

        <button
          class="cookie-button"
          id="cookie-button"
          type="button"
          aria-label="Gagner un trump dollar"
        >
          <span class="cookie-halo" aria-hidden="true"></span>
          <span class="character-effects" id="character-effects" aria-hidden="true"></span>
          <span class="character-stage" aria-hidden="true">
            <img
              class="trump-frame trump-frame-active"
              id="trump-frame-a"
              src="/images/trump/trump-1%202.webp"
              alt=""
              draggable="false"
            />
            <img
              class="trump-frame"
              id="trump-frame-b"
              src="/images/trump/trump-2%202.webp"
              alt=""
              draggable="false"
            />
          </span>
        </button>

        <div class="game-stats" aria-label="Statistiques">
          <dl class="stat-list">
            <div class="stat-card stat-card-green">
              <dt>Trump dollars par seconde</dt>
              <dd><span id="cookies-per-second"><%= formattedCookiesPerSecond %></span></dd>
            </div>
            <div class="stat-card stat-card-gold">
              <dt>Trump dollars par click</dt>
              <dd><span id="cookies-per-click"><%= formattedCookiesPerClick %></span></dd>
            </div>
            <div class="stat-card stat-card-red">
              <dt>Nombre d'upgrades</dt>
              <dd><span id="upgrade-count"><%= upgradeCount %></span></dd>
            </div>
          </dl>
          <p class="feedback" id="game-feedback" role="status"></p>
        </div>
      </section>

      <aside class="shop-panel" aria-label="Améliorations">
        <button
          class="shop-edge-chevron"
          id="shop-close"
          type="button"
          aria-label="Fermer la boutique"
        >
          <i class="ph ph-caret-right" aria-hidden="true"></i>
        </button>
        <div class="shop-actions" aria-label="Filtres boutique">
          <button
            class="shop-filter"
            id="shop-filter-auto"
            type="button"
            data-upgrade-filter="auto-click"
            aria-label="Afficher les améliorations automatiques"
          >
            <i class="ph ph-timer" aria-hidden="true"></i>
          </button>
          <button
            class="shop-filter"
            id="shop-filter-click"
            type="button"
            data-upgrade-filter="boost-click"
            aria-label="Afficher les boosts de clic"
          >
            <i class="ph ph-hand-tap" aria-hidden="true"></i>
          </button>
        </div>
        <div class="shop-head">
          <p class="eyebrow">Upgrades</p>
          <h2>Améliorations</h2>
        </div>
        <button class="shop-logout" id="logout-button" type="button" aria-label="Déconnexion">
          <i class="ph ph-sign-out" aria-hidden="true"></i>
          <span>Déconnexion</span>
        </button>
        <div class="shop-list" id="shop-list">
          <% upgrades.forEach((upgrade) => { %>
            <article
              class="upgrade-card"
              data-upgrade-key="<%= upgrade.key %>"
              data-upgrade-filter-kind="<%= upgrade.kind === 'auto' ? 'auto-click' : 'boost-click' %>"
            >
              <img
                class="upgrade-art"
                src="<%= upgrade.image %>"
                alt=""
                width="72"
                height="72"
                draggable="false"
              />
              <div class="upgrade-copy">
                <div class="upgrade-heading">
                  <h3><%= upgrade.name %></h3>
                  <p class="upgrade-kind">
                    <%= upgrade.kind === "auto" ? "Auto-click" : "Boost de clic" %>
                  </p>
                </div>
                <p class="upgrade-description"><%= upgrade.description %></p>
                <dl class="upgrade-meta">
                  <div>
                    <dt>Effet</dt>
                    <dd>
                      <%= upgrade.kind === "auto" ? `+${upgrade.effectValue}/s` : `+${upgrade.effectValue} par clic` %>
                    </dd>
                  </div>
                  <div>
                    <dt>Niveau</dt>
                    <dd data-upgrade-owned><%= upgrade.owned %></dd>
                  </div>
                </dl>
              </div>
              <button
                class="upgrade-buy"
                type="button"
                data-upgrade-buy
                data-upgrade-price="<%= upgrade.currentPrice %>"
              >
                Acheter -
                <span data-upgrade-price-label>$<%= upgrade.formattedCurrentPrice %></span>
              </button>
            </article>
          <% }) %>
        </div>
      </aside>
    </main>

    <script src="/scripts/constants.js"></script>
    <script src="/scripts/ui-helpers.js"></script>
    <script src="/scripts/auth-client.js"></script>
    <script src="/scripts/game-client.js"></script>
    <script src="/scripts/game-effects.js"></script>
    <script src="/scripts/trump-character.js"></script>
    <script src="/scripts/sound-effects.js"></script>
    <script src="/scripts/game-page.js"></script>
  </body>
</html>
