<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      rel="stylesheet"
      href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css"
    />
    <link rel="stylesheet" href="/styles/main.css" />
  </head>
  <body>
    <main class="page-shell auth-single">
      <section class="content-panel">
        <article class="form-panel accent-panel">
          <div class="panel-head">
            <h2>Créer un compte</h2>
            <p>Votre adresse email et votre mot de passe suffisent pour commencer.</p>
          </div>

          <form id="register-form" class="auth-form">
            <label for="register-email">Adresse email</label>
            <input id="register-email" name="email" type="email" autocomplete="email" required />

            <label for="register-password">Mot de passe</label>
            <div class="password-field">
              <input
                id="register-password"
                name="password"
                type="password"
                autocomplete="new-password"
                required
              />
              <button
                type="button"
                class="password-toggle"
                data-toggle-password
                data-target="register-password"
                aria-label="Afficher le mot de passe"
              >
                <i class="ph ph-eye"></i>
              </button>
            </div>

            <label for="register-password-confirmation">Confirmation du mot de passe</label>
            <div class="password-field">
              <input
                id="register-password-confirmation"
                name="passwordConfirmation"
                type="password"
                autocomplete="new-password"
                required
              />
              <button
                type="button"
                class="password-toggle"
                data-toggle-password
                data-target="register-password-confirmation"
                aria-label="Afficher le mot de passe"
              >
                <i class="ph ph-eye"></i>
              </button>
            </div>

            <button type="submit" class="primary-action">Créer un compte</button>
          </form>

          <p id="feedback" class="feedback" aria-live="polite"></p>

          <p class="switch-text">
            Vous avez déjà un compte ?
            <a href="/login">Se connecter</a>
          </p>
        </article>
      </section>
    </main>
    <script src="/scripts/auth-client.js"></script>
    <script src="/scripts/password-toggle.js"></script>
    <script src="/scripts/register-page.js"></script>
  </body>
</html>
